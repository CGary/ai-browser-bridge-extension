{
  "manifest_version": 3,
  "name": "AI Browser Bridge Extension",
  "version": "0.1.0",
  "description": "Bridge between AI automation daemon and browser DOM",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
